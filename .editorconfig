# ============================================
# MANSA - EditorConfig
# Maintains consistent coding styles
# https://editorconfig.org
# ============================================

# Top-most EditorConfig file
root = true

# ============================================
# All Files
# ============================================

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ============================================
# JavaScript & TypeScript
# ============================================

[*.{js,jsx,mjs,cjs,ts,tsx}]
indent_size = 2
quote_type = single

# ============================================
# JSON
# ============================================

[*.json]
indent_size = 2

[package.json]
indent_size = 2

# ============================================
# YAML
# ============================================

[*.{yml,yaml}]
indent_size = 2

# ============================================
# HTML
# ============================================

[*.html]
indent_size = 2

# ============================================
# CSS & Preprocessors
# ============================================

[*.{css,scss,sass,less}]
indent_size = 2

# ============================================
# Markdown
# ============================================

[*.md]
trim_trailing_whitespace = false
indent_size = 2

# ============================================
# Shell Scripts
# ============================================

[*.sh]
indent_size = 4
indent_style = space

# ============================================
# Makefiles
# ============================================

[Makefile]
indent_style = tab

# ============================================
# Python (for future tools)
# ============================================

[*.py]
indent_size = 4

# ============================================
# Config Files
# ============================================

[.gitignore]
indent_size = 2

[.eslintrc*]
indent_size = 2

[.prettierrc*]
indent_size = 2