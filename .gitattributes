# ============================================
# MANSA - .gitattributes
# File handling configuration
# ============================================

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# ============================================
# Source Code
# ============================================

# JavaScript
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf
*.jsonc text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf

# HTML
*.html text eol=lf
*.htm text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# XML
*.xml text eol=lf
*.svg text eol=lf

# ============================================
# Configuration Files
# ============================================

*.config.* text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.eslintrc* text eol=lf
.prettierrc* text eol=lf
.babelrc* text eol=lf
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf

# Environment files
.env* text eol=lf

# ============================================
# Shell Scripts
# ============================================

*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ============================================
# Binary Files
# ============================================

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Audio/Video
*.mp3 binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# ============================================
# Git LFS (Large File Storage)
# ============================================

# Uncomment if using Git LFS for large files
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.ai filter=lfs diff=lfs merge=lfs -text
# *.mp4 filter=lfs diff=lfs merge=lfs -text

# ============================================
# Diff Settings
# ============================================

# Better diff for JSON
*.json diff=json

# Better diff for images (show changes as text)
*.png diff=exif
*.jpg diff=exif
*.jpeg diff=exif

# ============================================
# Linguist (GitHub Language Stats)
# ============================================

# Mark vendor code as such
node_modules/** linguist-vendored
vendor/** linguist-vendored
dist/** linguist-generated
build/** linguist-generated

# Documentation
*.md linguist-documentation
docs/** linguist-documentation
