# ─────────────────────────────────────────────────────────────────────────────
# MANSA - Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# نسخ هذا الملف إلى .env.development و .env.production وملأ القيم الحقيقية
# Copy this file to .env.development and .env.production, then fill real values
#
# ⚠️ تحذير: لا ترفع .env.development أو .env.production إلى Git أبداً
# ⚠️ Warning: NEVER commit .env.development or .env.production to Git
# ─────────────────────────────────────────────────────────────────────────────

# ─── بيئة التشغيل | Environment ──────────────────────────────────────────────
# ⚠️  Do NOT set NODE_ENV here — Vite sets it automatically from the --mode flag.
#     If you copy this file to .env.production with NODE_ENV=development,
#     your production build will silently run in development mode.
# Note: APP_NAME and APP_VERSION are hardcoded in src/js/config/constants.js — not env-driven

# ─── Firebase Configuration ───────────────────────────────────────────────────
# احصل على هذه القيم من: Firebase Console → Project Settings → Your Apps
# Get from: https://console.firebase.google.com → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# احصل على هذه القيم من: Azure Portal → Storage Account → Shared Access Signature
# Get from: https://portal.azure.com → Storage Account → Shared Access Signature
VITE_AZURE_STORAGE_ACCOUNT=
VITE_AZURE_CONTAINER=mansa-public
VITE_AZURE_SAS_TOKEN=
VITE_AZURE_CDN_URL=

# ─── AI Services ──────────────────────────────────────────────────────────────
# Groq (AI chatbot): https://console.groq.com
VITE_GROQ_API_KEY=
# Google Gemini (image analysis): https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── Application URLs ─────────────────────────────────────────────────────────
VITE_APP_URL=https://mansa.azurestaticapps.net
VITE_API_URL=
# Note: CDN URL is VITE_AZURE_CDN_URL (under Azure section above) — not a separate variable

# ─── Firebase Emulator ────────────────────────────────────────────────────────
# true = يتصل بـ Firebase Emulator المحلي (للتطوير فقط)
# true = connects to local Firebase Emulator (development only)
# false = يتصل بـ Firebase الحقيقي (للإنتاج)
VITE_USE_EMULATOR=false

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_NOTIFICATIONS=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true

# ─── Dev Server ───────────────────────────────────────────────────────────────
VITE_PORT=3000
VITE_DEBUG=false
VITE_MOCK_API=false


# ─────────────────────────────────────────────────────────────────────────────
# NOTES | ملاحظات
# ─────────────────────────────────────────────────────────────────────────────
# 1. NEVER commit .env.development or .env.production to Git
# 2. VITE_ prefix = exposed to browser JS (keep secrets out of Vite prefix)
# 3. Restart dev server after any change to .env files
# 4. Update this file whenever you add a new VITE_ variable
# ─────────────────────────────────────────────────────────────────────────────
