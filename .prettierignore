# ─────────────────────────────────────────────────────────────────────────────
# MANSA - .prettierignore
# الملفات والمجلدات التي يتجاهلها Prettier | Files Prettier should not format
# ─────────────────────────────────────────────────────────────────────────────

# ─── مخرجات البناء | Build Outputs ──────────────────────────────────────────
dist/
build/
out/
.vite/

# ─── الاعتمادات | Dependencies ───────────────────────────────────────────────
node_modules/

# ─── تقارير التغطية | Coverage Reports ──────────────────────────────────────
coverage/
.nyc_output/

# ─── ملفات مضغوطة | Minified Files ──────────────────────────────────────────
# فرمتة الملفات المضغوطة مضيعة للوقت
*.min.js
*.min.css
*.min.html

# ─── ملفات قفل الاعتمادات | Lock Files ──────────────────────────────────────
# هذه الملفات تُنشأ تلقائياً ولا تحتاج تنسيقاً يدوياً
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── أدوات الـ CI/CD ──────────────────────────────────────────────────────────
.github/

# ─── مكتبات الطرف الثالث | Third-party Vendor Assets ────────────────────────
public/assets/vendors/

# ─── ملفات خاصة بـ VSCode ────────────────────────────────────────────────────
.vscode/

# ─── ملفات مؤقتة | Temporary Files ──────────────────────────────────────────
*.tmp
*.temp
.cache/
.temp/

# ─── تقارير الأداء | Performance Reports ────────────────────────────────────
.lighthouseci/
lighthouse-report/
