{
  "name": "mansa",
  "version": "0.1.0",
  "description": "منصة تعليمية تفاعلية لطلاب السنة الأولى - كلية الحاسبات والمعلومات",
  "private": true,
  "type": "module",
  "keywords": [
    "education",
    "arabic",
    "pwa",
    "firebase",
    "students",
    "quiz",
    "learning",
    "interactive",
    "university"
  ],
  "author": {
    "name": "MANSA Team",
    "email": "team@mansa.edu"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MANSA-Project/MANSA.git"
  },
  "bugs": {
    "url": "https://github.com/MANSA-Project/MANSA/issues"
  },
  "homepage": "https://mansa.azurestaticapps.net",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint src/js tests",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint src/js tests --fix",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepare": "is-ci || husky install",
    "precommit": "lint-staged",
    "lighthouse": "lhci autorun",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "firebase": "^10.14.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "@lhci/cli": "^0.13.0",
    "@vitejs/plugin-legacy": "^5.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^17.3.0",
    "husky": "^8.0.3",
    "is-ci": "^3.0.1",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "vite": "^5.4.21",
    "vite-bundle-visualizer": "^1.0.0",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.6.1",
    "workbox-window": "^7.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "cross-env ESLINT_USE_FLAT_CONFIG=true eslint --fix",
      "prettier --write"
    ],
    "*.{css,html}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ]
}
